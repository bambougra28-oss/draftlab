{
    "name": "draftlab",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.5.1",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "coverage:tags": "node --experimental-strip-types --no-warnings scripts/checkTagCoverage.ts",
        "backtest": "node --experimental-strip-types --no-warnings scripts/backtest/runCorpus.ts"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "sharp",
            "workerd"
        ]
    },
    "devDependencies": {
        "@eslint/js": "^9.10.0",
        "@sveltejs/adapter-cloudflare": "^4.7.0",
        "@sveltejs/kit": "^2.20.0",
        "@sveltejs/vite-plugin-svelte": "^4.0.0",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^22.0.0",
        "eslint": "^9.10.0",
        "eslint-plugin-svelte": "^3.0.0",
        "fake-indexeddb": "^6.2.5",
        "globals": "^15.9.0",
        "linkedom": "^0.18.12",
        "marked": "^18.0.3",
        "svelte": "^5.0.0",
        "svelte-check": "^4.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.5.0",
        "typescript-eslint": "^8.0.0",
        "vite": "^5.4.0",
        "vitest": "^2.1.0"
    }
}
